// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────────────────────────

enum BillType {
  software
  utility
  other
}

// ── Models ─────────────────────────────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  privyUserId String   @unique @map("privy_user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  wallet    Wallet?
  deposits  Deposit[]
  snapshots YieldSnapshot[]
  bills     RecurringBill[]

  @@map("companies")
}

model Wallet {
  id             String   @id @default(cuid())
  companyId      String   @unique @map("company_id")
  stellarAddress String   @unique @map("stellar_address")
  createdAt      DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("wallets")
}

model Deposit {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  /// USDC amount in base units (7 decimal places)
  amount    BigInt
  txHash    String   @unique @map("tx_hash")
  createdAt DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  // principal() agrega deposits por companyId; índice evita full-scan.
  @@index([companyId])
  @@map("deposits")
}

model RecurringBill {
  id          String   @id @default(cuid())
  companyId   String   @map("company_id")
  vendor      String
  /// USDC amount in base units (7 decimal places)
  monthlyCost BigInt   @map("monthly_cost")
  type        BillType @default(software)
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("recurring_bills")
}

model YieldSnapshot {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  /// Vault value in base units (7 decimal places)
  vaultValue BigInt   @map("vault_value")
  /// Principal in base units (7 decimal places)
  principal  BigInt
  /// Spendable yield in base units (7 decimal places)
  spendable  BigInt
  createdAt  DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, createdAt])
  @@map("yield_snapshots")
}
